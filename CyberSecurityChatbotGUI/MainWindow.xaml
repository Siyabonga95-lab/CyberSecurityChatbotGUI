<Window x:Class="CyberSecurityChatbotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIYA'S CYBER CHATBOT — Stay Safe Online"
        Height="750" Width="950"
        MinHeight="600" MinWidth="750"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">

    <!-- ================================================================
         MAIN WINDOW LAYOUT
         The window is split into two main sections (rows):
           Row 0 = Header (logo/ASCII art + session info)
           Row 1 = Chat area (conversation + input)
         ================================================================ -->

    <Window.Resources>
        <!-- ============================================================
             COLOUR SCHEME (cybersecurity / dark tech theme)
             Primary background : #0D1117  (very dark navy — like GitHub dark)
             Panel background   : #161B22  (slightly lighter dark)
             Accent cyan        : #00C8FF  (bright cyan — "hacker" feel)
             Accent green       : #39D353  (bright green — success / bot)
             User message colour: #FF7B72  (soft red-orange — user messages)
             Border colour      : #30363D  (subtle grey borders)
             Text colour        : #E6EDF3  (off-white readable text)
             ============================================================ -->

        <!-- STYLE: ScrollViewer — removes default focus border -->
        <Style x:Key="ChatScrollStyle" TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- STYLE: Send button -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00C8FF"/>
            <Setter Property="Foreground" Value="#0D1117"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#39D353"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- STYLE: Clear button -->
        <Style x:Key="ClearButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363D"/>
                    <Setter Property="Foreground" Value="#E6EDF3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- STYLE: Topic quick-access buttons along the bottom -->
        <Style x:Key="TopicButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="3,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0D1117"/>
                    <Setter Property="Foreground" Value="#00C8FF"/>
                    <Setter Property="BorderBrush" Value="#00C8FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- STYLE: Input TextBox -->
        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="CaretBrush" Value="#00C8FF"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#00C8FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- OUTER GRID: Header row + Chat row -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Row 0: Header -->
            <RowDefinition Height="*"/>
            <!-- Row 1: Chat area -->
            <RowDefinition Height="Auto"/>
            <!-- Row 2: Quick topic buttons -->
            <RowDefinition Height="Auto"/>
            <!-- Row 3: Input bar -->
            <RowDefinition Height="Auto"/>
            <!-- Row 4: Status bar -->
        </Grid.RowDefinitions>

        <!-- ============================================================
             ROW 0 — HEADER / ASCII ART BANNER
             This satisfies Requirement 1: "ASCII art implemented in task 1
             is translated into the GUI effectively"
             ============================================================ -->
        <Border Grid.Row="0"
                Background="#161B22"
                BorderBrush="#30363D"
                BorderThickness="0,0,0,1"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ASCII-style title block (left side) -->
                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <!-- The big ASCII-art-style title rendered as styled text -->
                    <TextBlock FontFamily="Consolas"
                               FontSize="11"
                               Foreground="#00C8FF"
                               LineHeight="16"
                               xml:space="preserve">╔════════════════════════════════════╗
║     SIYA'S CYBER CHATBOT           ║
║     Stay Safe Online! 🛡️            ║
╚════════════════════════════════════╝</TextBlock>

                    <!-- Subtitle tagline -->
                    <TextBlock Text="Your personal cybersecurity assistant — powered by knowledge"
                               FontFamily="Consolas"
                               FontSize="11"
                               Foreground="#8B949E"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Session info panel (right side) -->
                <StackPanel Grid.Column="1"
                            Orientation="Vertical"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <!-- Session time — updated by code-behind -->
                    <TextBlock x:Name="txtSessionTime"
                               Text="⏱  Session: 0 min, 0 sec"
                               FontFamily="Consolas"
                               FontSize="11"
                               Foreground="#8B949E"
                               HorizontalAlignment="Right"/>

                    <!-- Questions asked counter -->
                    <TextBlock x:Name="txtQuestionCount"
                               Text="💬 Questions: 0"
                               FontFamily="Consolas"
                               FontSize="11"
                               Foreground="#8B949E"
                               Margin="0,3,0,0"
                               HorizontalAlignment="Right"/>

                    <!-- Memory indicator — shows user's favourite topic when set -->
                    <TextBlock x:Name="txtMemoryIndicator"
                               Text=""
                               FontFamily="Consolas"
                               FontSize="11"
                               Foreground="#39D353"
                               Margin="0,3,0,0"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================================
             ROW 1 — CHAT CONVERSATION AREA
             This is where the messages appear (like WhatsApp bubbles)
             ============================================================ -->
        <Border Grid.Row="1"
                Background="#0D1117"
                Padding="0">

            <ScrollViewer x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Style="{StaticResource ChatScrollStyle}"
                          Padding="16,12">

                <!-- StackPanel holds all the message bubbles.
                     Code-behind adds TextBlock/Border children dynamically. -->
                <StackPanel x:Name="ChatPanel"
                            Orientation="Vertical"
                            Margin="0"/>
            </ScrollViewer>
        </Border>

        <!-- ============================================================
             ROW 2 — QUICK TOPIC SHORTCUT BUTTONS
             These let the user click a topic instead of typing it.
             Each button's Click event is handled in code-behind.
             ============================================================ -->
        <Border Grid.Row="2"
                Background="#161B22"
                BorderBrush="#30363D"
                BorderThickness="0,1,0,0"
                Padding="16,8">
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="Quick topics: "
                           FontFamily="Consolas"
                           FontSize="11"
                           Foreground="#8B949E"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>

                <Button x:Name="btnPhishing"
                        Content="🎣 Phishing"
                        Style="{StaticResource TopicButtonStyle}"
                        Click="TopicButton_Click"/>

                <Button x:Name="btnPasswords"
                        Content="🔑 Passwords"
                        Style="{StaticResource TopicButtonStyle}"
                        Click="TopicButton_Click"/>

                <Button x:Name="btnPrivacy"
                        Content="🔒 Privacy"
                        Style="{StaticResource TopicButtonStyle}"
                        Click="TopicButton_Click"/>

                <Button x:Name="btnScams"
                        Content="⚠️ Scams"
                        Style="{StaticResource TopicButtonStyle}"
                        Click="TopicButton_Click"/>

                <Button x:Name="btnViruses"
                        Content="🦠 Viruses"
                        Style="{StaticResource TopicButtonStyle}"
                        Click="TopicButton_Click"/>

                <Button x:Name="btnLinks"
                        Content="🔗 Links"
                        Style="{StaticResource TopicButtonStyle}"
                        Click="TopicButton_Click"/>

                <Button x:Name="btnMenu"
                        Content="📋 Menu"
                        Style="{StaticResource TopicButtonStyle}"
                        Click="TopicButton_Click"/>
            </WrapPanel>
        </Border>

        <!-- ============================================================
             ROW 3 — INPUT BAR (TextBox + Send + Clear buttons)
             ============================================================ -->
        <Border Grid.Row="3"
                Background="#161B22"
                BorderBrush="#30363D"
                BorderThickness="0,1,0,0"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <!-- TextBox fills remaining space -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Send button -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Clear button -->
                </Grid.ColumnDefinitions>

                <!-- USER INPUT TEXTBOX
                     - KeyDown event sends message when Enter is pressed
                     - x:Name allows code-behind to read/clear it -->
                <TextBox x:Name="txtInput"
                         Grid.Column="0"
                         Style="{StaticResource InputBoxStyle}"
                         Height="42"
                         ToolTip="Type your message here and press Enter or click Send"
                         KeyDown="txtInput_KeyDown"
                         Margin="0,0,8,0"/>

                <!-- SEND BUTTON -->
                <Button x:Name="btnSend"
                        Grid.Column="1"
                        Content="SEND ▶"
                        Style="{StaticResource SendButtonStyle}"
                        Height="42"
                        Width="90"
                        Click="btnSend_Click"
                        Margin="0,0,8,0"/>

                <!-- CLEAR CHAT BUTTON -->
                <Button x:Name="btnClear"
                        Grid.Column="2"
                        Content="CLEAR"
                        Style="{StaticResource ClearButtonStyle}"
                        Height="42"
                        Width="70"
                        Click="btnClear_Click"/>
            </Grid>
        </Border>

        <!-- ============================================================
             ROW 4 — STATUS BAR (shows hints at the bottom)
             ============================================================ -->
        <Border Grid.Row="4"
                Background="#161B22"
                BorderBrush="#30363D"
                BorderThickness="0,1,0,0"
                Padding="16,5">
            <TextBlock x:Name="txtStatus"
                       Text="💡 Tip: Type 'menu' for all topics | Say 'I'm interested in privacy' to set a favourite topic | Type 'tell me more' for follow-up tips"
                       FontFamily="Consolas"
                       FontSize="10"
                       Foreground="#8B949E"/>
        </Border>
    </Grid>
</Window>
